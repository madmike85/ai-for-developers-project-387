{
  "ci": {
    "collect": {
      "url": ["http://localhost:4173"],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "onlyCategories": [
          "performance",
          "accessibility",
          "best-practices",
          "seo",
          "pwa"
        ],
        "skipAudits": []
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci",
      "reportFilenamePattern": "%%PATHNAME%%-%%DATETIME%%-report.%%EXTENSION%%"
    },
    "assert": {
      "preset": "lighthouse:no-pwa"
    }
  }
}
